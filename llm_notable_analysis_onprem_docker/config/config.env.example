# Dockerized on-prem notable analyzer configuration
# Copy this file to config/config.env before starting the stack.

INGEST_MODE=file_drop

# Mounted data directories inside the analyzer container
INCOMING_DIR=/watch/incoming
PROCESSED_DIR=/watch/processed
QUARANTINE_DIR=/watch/quarantine
REPORT_DIR=/watch/reports
ARCHIVE_DIR=/watch/archive

POLL_INTERVAL=5

# Internal Docker network endpoint for the model-serving container
LLM_API_URL=http://model-serving:8000/v1/chat/completions
LLM_API_TOKEN=
LLM_MODEL_NAME=Phi-3.5-mini-instruct-Q4_K_M.gguf
LLM_MAX_TOKENS=1024
# HTTP connect+read timeout for each LLM request (seconds). CPU-only Phi + long prompts often exceed 120s.
LLM_TIMEOUT=300

# Optional retrieval grounding
RAG_ENABLED=false
RAG_SQLITE_PATH=/kb/index/kb.sqlite3
RAG_FAISS_PATH=/kb/index/kb.faiss
RAG_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
RAG_MAX_SNIPPETS_120B=5
RAG_MAX_SNIPPETS_20B=4
RAG_CONTEXT_BUDGET_CHARS_120B=2200
RAG_CONTEXT_BUDGET_CHARS_20B=1600

# Optional Splunk writeback
SPLUNK_SINK_ENABLED=false
SPL_QUERY_GENERATION_ENABLED=false
SPLUNK_BASE_URL=
SPLUNK_API_TOKEN=
SPLUNK_NOTABLE_UPDATE_PATH=/services/notable_update
SPLUNK_CA_BUNDLE=

# Bundled MITRE ATT&CK data in the analyzer image
MITRE_IDS_PATH=/app/onprem_service/enterprise_attack_v17.1_ids.json

# Retention housekeeping
INPUT_RETENTION_DAYS=2
REPORT_RETENTION_DAYS=7
ARCHIVE_RETENTION_DAYS=14
RETENTION_RUN_INTERVAL_SECONDS=86400

# Optional concurrency
CONCURRENCY_ENABLED=false
MAX_WORKERS=1
MAX_QUEUE_DEPTH=8
