# Copy to .env and edit as needed for a specific deployment.

# Container user mapping for writable host-mounted volumes.
CONTAINER_UID=1000
CONTAINER_GID=1000

# Host-mounted vLLM model directory under ./models
# Example expected host path: ./models/gpt-oss-120b/config.json
VLLM_MODEL_DIRNAME=gpt-oss-120b
VLLM_SERVED_MODEL_NAME=gpt-oss-120b

# GPU runtime knobs for Docker Compose hosts with NVIDIA support.
MODEL_SERVING_GPU_COUNT=all
MODEL_SERVING_SHM_SIZE=8gb
NVIDIA_VISIBLE_DEVICES=all
NVIDIA_DRIVER_CAPABILITIES=compute,utility

# vLLM runtime defaults aligned with onprem_vllm_service baseline.
VLLM_GPU_MEMORY_UTILIZATION=0.9
VLLM_MAX_MODEL_LEN=131072
VLLM_DTYPE=auto
VLLM_DISTRIBUTED_EXECUTOR_BACKEND=mp

# Air-gapped / registry-only (use with compose.airgap.yaml only). Canonical: docs/canonical-repos.md
# MODEL_SERVING_IMAGE=ghcr.io/dreyna001/vllm-openai-gptoss120b:v0.14.1
# ANALYZER_IMAGE=ghcr.io/dreyna001/notable-analyzer-service:1.0.0
