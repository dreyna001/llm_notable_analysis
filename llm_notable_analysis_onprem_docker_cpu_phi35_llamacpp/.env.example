# Copy to .env and edit as needed for a specific deployment.

# Container user mapping for writable host-mounted volumes.
CONTAINER_UID=1000
CONTAINER_GID=1000

# GGUF filename under ./models
LLM_MODEL_FILENAME=Phi-3.5-mini-instruct-Q4_K_M.gguf

# llama.cpp server tuning (set threads near host logical CPU count for faster CPU inference)
LLAMA_THREADS=4
LLAMA_THREADS_BATCH=4
LLAMA_PARALLEL=1
LLAMA_CTX_SIZE=16384
LLAMA_N_PREDICT=1024
LLAMA_CACHE_TYPE_K=q8_0
LLAMA_CACHE_TYPE_V=q8_0

# Air-gapped / registry-only (use with compose.airgap.yaml only). Canonical: docs/canonical-repos.md
# MODEL_SERVING_IMAGE=ghcr.io/dreyna001/llama-cpp-server-cpu-phi35-llamacpp:server
# ANALYZER_IMAGE=ghcr.io/dreyna001/notable-analyzer-service:1.0.0
