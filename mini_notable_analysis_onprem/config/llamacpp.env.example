# llama.cpp PoC service configuration example
# Installed runtime env path: /etc/llamacpp/llamacpp.env

# Network
LLAMA_HOST=127.0.0.1
LLAMA_PORT=8080

# Model
LLAMA_MODEL_PATH=/opt/llamacpp/models/Qwen3-4B-Q4_K_M.gguf

# Runtime controls
LLAMA_THREADS=10
LLAMA_THREADS_BATCH=12
LLAMA_PARALLEL=1
LLAMA_CTX_SIZE=8192
LLAMA_MAX_INPUT_TOKENS=3072
LLAMA_DEFAULT_MAX_TOKENS=384
LLAMA_HARD_MAX_TOKENS=512
LLAMA_INFERENCE_TIMEOUT_SECONDS=120
LLAMA_HTTP_TIMEOUT_SECONDS=180

# Cache and feature flags
LLAMA_CACHE_TYPE_K=q8_0
LLAMA_CACHE_TYPE_V=q8_0
LLAMA_CONT_BATCHING_FLAG=--cont-batching
LLAMA_MMAP_FLAG=
LLAMA_MLOCK_FLAG=
LLAMA_EXTRA_ARGS=
