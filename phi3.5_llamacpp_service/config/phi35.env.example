# Offline/non-root Phi-3.5 llama.cpp runtime config example

# Local pre-staged source tree (no git clone/fetch by installer)
PHI_RUNTIME_SRC_DIR=$HOME/.local/share/phi35_llamacpp/runtime/llama.cpp
PHI_EXPECTED_RUNTIME_COMMIT=149b249

# Local pre-staged model artifact (pinned baseline)
# Source: https://huggingface.co/bartowski/Phi-3.5-mini-instruct-GGUF
# Revision: b1693692c4758ac83f0d0e65aff9b4f945f29941
PHI_MODEL_PATH=$HOME/.local/share/phi35_llamacpp/models/Phi-3.5-mini-instruct-Q4_K_M.gguf
PHI_MODEL_SHA256=e4165e3a71af97f1b4820da61079826d8752a2088e313af0c7d346796c38eff5

# Runtime endpoint + perf knobs
PHI_HOST=127.0.0.1
PHI_PORT=8000
PHI_THREADS=4
PHI_THREADS_BATCH=4
PHI_PARALLEL=1
PHI_CTX_SIZE=4096
PHI_N_PREDICT=1024
PHI_CACHE_TYPE_K=q8_0
PHI_CACHE_TYPE_V=q8_0

# Behavior toggles
PHI_SKIP_RUNTIME_BUILD=false
PHI_AUTO_START=true
PHI_STOP_EXISTING=true
PHI_CONT_BATCHING=true
PHI_MMAP=true
PHI_MLOCK=false
PHI_HEALTH_TIMEOUT_SECONDS=180

# Optional
PHI_EXTRA_ARGS=
