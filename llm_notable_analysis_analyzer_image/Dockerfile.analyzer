FROM python:3.13-slim-bookworm

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PIP_NO_CACHE_DIR=1

WORKDIR /app

RUN apt-get update \
    && apt-get install -y --no-install-recommends ca-certificates \
    && rm -rf /var/lib/apt/lists/*

COPY llm_notable_analysis_analyzer_image/requirements.analyzer-docker.txt /tmp/requirements.txt
RUN pip install --upgrade pip \
    && pip install -r /tmp/requirements.txt

COPY llm_notable_analysis_onprem_docker_gpu_gptoss120b_vllm/onprem_service /app/onprem_service
COPY llm_notable_analysis_onprem_docker_gpu_gptoss120b_vllm/onprem_rag /app/onprem_rag

RUN useradd --create-home --home-dir /home/analyzer --shell /usr/sbin/nologin analyzer \
    && chown -R analyzer:analyzer /app

USER analyzer

ENTRYPOINT ["python", "-m", "onprem_service.onprem_main_nonsdk"]
