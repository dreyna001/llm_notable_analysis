[Unit]
Description=Notable Analysis Service (On-Prem LLM)
Documentation=https://github.com/your-org/notable-analyzer
After=network.target vllm.service
Wants=vllm.service

[Service]
Type=simple
User=notable-analyzer
Group=notable-analyzer

# Working directory
WorkingDirectory=/opt/notable-analyzer

# Environment file with configuration
EnvironmentFile=/etc/notable-analyzer/config.env

# Python virtual environment activation and service start
ExecStart=/opt/notable-analyzer/venv/bin/python -m onprem_service.onprem_main

# Graceful shutdown
TimeoutStopSec=30
KillMode=mixed
KillSignal=SIGTERM

# Restart policy
Restart=on-failure
RestartSec=10

# Security hardening
NoNewPrivileges=yes
CapabilityBoundingSet=
AmbientCapabilities=
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
ProtectKernelLogs=yes
RestrictNamespaces=yes
SystemCallArchitectures=native
LockPersonality=yes
RestrictAddressFamilies=AF_UNIX AF_INET AF_INET6
UMask=0077
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
# NOTE: INCOMING_DIR is often a symlink to the SFTP chroot drop path:
#   /var/notables/incoming -> /var/sftp/soar/incoming
# With ProtectSystem=strict, systemd will treat the *resolved* path as read-only
# unless explicitly allowed here. Without this, moves out of INCOMING_DIR can fail
# with "Read-only file system".
ReadWritePaths=/var/notables /var/sftp/soar

# Resource limits
LimitNOFILE=65535

# Logging
StandardOutput=journal
StandardError=journal
SyslogIdentifier=notable-analyzer

[Install]
WantedBy=multi-user.target

