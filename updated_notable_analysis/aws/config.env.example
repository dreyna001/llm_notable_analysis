# AWS wrapper runtime contract for updated_notable_analysis

# Required: destination bucket for report JSON output.
UPDATED_NOTABLE_AWS_REPORT_OUTPUT_BUCKET=replace-with-report-bucket

# Optional: output prefix within the report bucket.
UPDATED_NOTABLE_AWS_REPORT_OUTPUT_PREFIX=updated-notable-analysis/reports

# Optional: defaults used when invoke payload omits profile or bundle selections.
UPDATED_NOTABLE_AWS_DEFAULT_PROFILE_NAME=analysis_only
UPDATED_NOTABLE_AWS_DEFAULT_CUSTOMER_BUNDLE_NAME=acme_default
