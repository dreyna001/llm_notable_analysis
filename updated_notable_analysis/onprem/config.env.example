# On-prem wrapper runtime contract for updated_notable_analysis

# Local file-drop directories.
UPDATED_NOTABLE_ONPREM_INCOMING_DIR=/var/notables/incoming
UPDATED_NOTABLE_ONPREM_PROCESSED_DIR=/var/notables/processed
UPDATED_NOTABLE_ONPREM_QUARANTINE_DIR=/var/notables/quarantine
UPDATED_NOTABLE_ONPREM_REPORT_OUTPUT_DIR=/var/notables/reports

# Optional: defaults used when input files omit profile or bundle selections.
UPDATED_NOTABLE_ONPREM_DEFAULT_PROFILE_NAME=analysis_only
UPDATED_NOTABLE_ONPREM_DEFAULT_CUSTOMER_BUNDLE_NAME=acme_default

# Optional: local advisory context JSON indexes, one <index_name>.json per bundle index.
UPDATED_NOTABLE_ONPREM_ADVISORY_CONTEXT_DIR=/var/notables/context

# Local LiteLLM readiness gate for the analyzer-facing endpoint.
UPDATED_NOTABLE_ONPREM_LITELLM_BASE_URL=http://127.0.0.1:4000
UPDATED_NOTABLE_ONPREM_LITELLM_READINESS_PATH=/v1/models
UPDATED_NOTABLE_ONPREM_READINESS_TIMEOUT_SECONDS=2
UPDATED_NOTABLE_ONPREM_LITELLM_CHAT_COMPLETIONS_PATH=/v1/chat/completions
UPDATED_NOTABLE_ONPREM_LITELLM_MODEL_NAME=gemma-4-31B-it
UPDATED_NOTABLE_ONPREM_LITELLM_REQUEST_TIMEOUT_SECONDS=60

# Worker-loop controls for the systemd-managed analyzer service.
UPDATED_NOTABLE_ONPREM_WORKER_IDLE_SLEEP_SECONDS=5
UPDATED_NOTABLE_ONPREM_WORKER_MAX_FILES_PER_POLL=10

# Runtime note: when the real injected core runner is wired, the intended on-prem
# chain remains LiteLLM -> vLLM -> gemma-4-31B-it on loopback/local host paths.
