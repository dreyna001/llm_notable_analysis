# On-prem Notable Analysis Service Configuration
# Copy to /etc/notable-analyzer/config.env and edit values

# =============================================================================
# Ingest Mode
# =============================================================================
# Ingest mode: file_drop (SOAR pushes notables via SFTP to INCOMING_DIR)
# This is the only supported ingest mode. See README.md for SFTP setup.
INGEST_MODE=file_drop

# =============================================================================
# Directories (for file_drop mode)
# =============================================================================
INCOMING_DIR=/var/notables/incoming
PROCESSED_DIR=/var/notables/processed
QUARANTINE_DIR=/var/notables/quarantine
REPORT_DIR=/var/notables/reports
ARCHIVE_DIR=/var/notables/archive

# Polling interval in seconds
POLL_INTERVAL=5

# =============================================================================
# Local LLM Configuration (vLLM)
# =============================================================================
# vLLM endpoint (localhost HTTP - no TLS needed for local)
LLM_API_URL=http://127.0.0.1:8000/v1/completions

# Optional API token (leave empty if vLLM runs without auth)
LLM_API_TOKEN=

# Model name (must match vLLM --served-model-name)
LLM_MODEL_NAME=gpt-oss-20b

# Max tokens for LLM response
LLM_MAX_TOKENS=4096

# Timeout for LLM API calls in seconds
LLM_TIMEOUT=120

# =============================================================================
# Splunk Integration (Optional)
# =============================================================================
# Enable REST API writeback to Splunk ES
SPLUNK_SINK_ENABLED=false

# Splunk base URL (e.g., https://splunk.internal:8089)
SPLUNK_BASE_URL=

# Splunk API token for REST authentication
SPLUNK_API_TOKEN=

# Path to PEM-format CA bundle for Splunk TLS verification.
# If your Splunk instance uses an internal/private CA not in the system trust
# store, set this to the path of your CA bundle (e.g., /etc/pki/tls/certs/internal-ca.pem).
# If empty, the system trust store is used (default, recommended if CA is installed system-wide).
# To install internal CA system-wide on RHEL: copy CA cert to /etc/pki/ca-trust/source/anchors/
# and run: sudo update-ca-trust
SPLUNK_CA_BUNDLE=

# =============================================================================
# MITRE ATT&CK Data
# =============================================================================
# Path to pre-extracted TTP IDs JSON file
# Default uses bundled file in onprem_service/ package directory
MITRE_IDS_PATH=/opt/notable-analyzer/onprem_service/enterprise_attack_v17.1_ids.json

# =============================================================================
# Retention Policy
# =============================================================================
# Stage 1: move old inputs/reports into ARCHIVE_DIR
INPUT_RETENTION_DAYS=2
REPORT_RETENTION_DAYS=7

# Stage 2: delete files from ARCHIVE_DIR after this many days in archive
ARCHIVE_RETENTION_DAYS=14

# How often to run retention housekeeping (seconds)
RETENTION_RUN_INTERVAL_SECONDS=86400

# =============================================================================
# Concurrency (Optional)
# =============================================================================
# Enable concurrent notable processing via Python multithreading (ThreadPoolExecutor)
# Default is sequential (one notable at a time)
CONCURRENCY_ENABLED=false

# Number of worker threads (multithreading) when concurrency is enabled
# A100 + gpt-oss-20b recommended:
# - Xeon Gold: 4
# - Xeon Platinum: 6
MAX_WORKERS=4

# Maximum pending files in queue before backpressure kicks in
# When queue is full, new files wait until next poll cycle
# A100 + gpt-oss-20b recommended:
# - Xeon Gold: 32
# - Xeon Platinum: 48
MAX_QUEUE_DEPTH=32

